---
const NAV = [
  { label: 'Insights', href: '/insights/' },
  { label: 'ICU', href: '/icu/' },
  { label: 'Work', href: '/work/' },
  { label: 'Podcast', href: '/podcast/' },
  { label: 'Team', href: '/team/' },
  { label: 'Events', href: '/events/' },
  { label: 'News', href: '/news/' },
  { label: 'Guides', href: '/guides/' },
];

const current = Astro.url.pathname;
---

<header class="bg-brand sticky top-0 z-50 shadow-md">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <span class="text-white font-bold text-xl tracking-tight">BPD Healthcare</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:flex items-center gap-1">
        {NAV.map(({ label, href }) => {
          const active = current === href || (href !== '/' && current.startsWith(href));
          return (
            <a
              href={href}
              class={[
                'px-3 py-2 rounded text-sm font-medium transition-colors',
                active
                  ? 'bg-white/20 text-white'
                  : 'text-blue-100 hover:bg-white/10 hover:text-white',
              ].join(' ')}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="menu-toggle"
        aria-label="Toggle menu"
        class="lg:hidden text-white p-2 rounded hover:bg-white/10"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav panel -->
  <div id="mobile-menu" class="hidden lg:hidden bg-brand-light border-t border-white/10">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
      {NAV.map(({ label, href }) => {
        const active = current === href || (href !== '/' && current.startsWith(href));
        return (
          <a
            href={href}
            class={[
              'px-3 py-2 rounded text-sm font-medium transition-colors',
              active ? 'bg-white/20 text-white' : 'text-blue-100 hover:bg-white/10 hover:text-white',
            ].join(' ')}
          >
            {label}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden', !open);
    iconClose?.classList.toggle('hidden', !!open);
  });
</script>
