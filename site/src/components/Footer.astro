---
const year = new Date().getFullYear();
---

<footer class="bg-brand text-blue-100 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <p class="text-white font-bold text-lg mb-2">BPD Healthcare</p>
        <p class="text-sm">Delivering the future to healthcare's leading brands.</p>
      </div>
      <div>
        <p class="text-white font-semibold mb-3">Content</p>
        <ul class="space-y-1 text-sm">
          <li><a href="/insights/" class="hover:text-white transition-colors">Insights</a></li>
          <li><a href="/icu/" class="hover:text-white transition-colors">ICU</a></li>
          <li><a href="/work/" class="hover:text-white transition-colors">Work</a></li>
          <li><a href="/podcast/" class="hover:text-white transition-colors">Podcast</a></li>
          <li><a href="/guides/" class="hover:text-white transition-colors">Guides</a></li>
        </ul>
      </div>
      <div>
        <p class="text-white font-semibold mb-3">Company</p>
        <ul class="space-y-1 text-sm">
          <li><a href="/team/" class="hover:text-white transition-colors">Team</a></li>
          <li><a href="/events/" class="hover:text-white transition-colors">Events</a></li>
          <li><a href="/news/" class="hover:text-white transition-colors">News</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 pt-6 border-t border-white/10 text-sm text-center">
      &copy; {year} BPD Healthcare. All rights reserved.
    </div>
  </div>
</footer>
