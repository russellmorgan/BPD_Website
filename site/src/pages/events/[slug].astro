---
import BaseLayout from '../../layouts/BaseLayout.astro';
import events from '../../data/events.json';
import { url } from '../../lib/url.js';

export function getStaticPaths() {
  return events.map((event) => ({
    params: { slug: event.slug },
    props: { event },
  }));
}

const { event } = Astro.props;
const { meta } = event;
const dateDisplay = meta.event_date_display || meta.event_date || '';
const location = meta.event_location || '';
const registrationUrl = meta.event_registration_url || '';
const excerpt = meta.event_excerpt?.replace(/<[^>]*>/g, '').slice(0, 160) || '';
---

<BaseLayout title={event.title} description={excerpt}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-sm text-slate-400 mb-6">
      <a href={url('/')} class="hover:text-accent">Home</a>
      <span class="mx-2">›</span>
      <a href={url('/events/')} class="hover:text-accent">Events</a>
      <span class="mx-2">›</span>
      <span class="text-slate-600 truncate">{event.title}</span>
    </nav>

    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase bg-amber-100 text-amber-800 mb-4">
      Event
    </span>

    <h1 class="text-3xl sm:text-4xl font-bold text-brand leading-tight mb-5">{event.title}</h1>

    <!-- Event meta -->
    {(dateDisplay || location || registrationUrl) && (
      <div class="bg-surface rounded-xl p-4 mb-8 flex flex-wrap gap-x-8 gap-y-3 text-sm">
        {dateDisplay && (
          <div class="flex items-center gap-2 text-slate-700">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            <span>{dateDisplay}</span>
          </div>
        )}
        {location && (
          <div class="flex items-center gap-2 text-slate-700">
            <svg class="w-4 h-4 text-accent flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span>{location}</span>
          </div>
        )}
        {registrationUrl && (
          <a
            href={registrationUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 bg-accent text-white text-xs font-semibold px-4 py-1.5 rounded-full hover:bg-brand transition-colors ml-auto"
          >
            Register
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        )}
      </div>
    )}

    {event.content
      ? <div class="prose" set:html={event.content} />
      : <p class="text-slate-500 italic">No details available for this event.</p>
    }

    <div class="mt-12 pt-8 border-t border-slate-100">
      <a href={url('/events/')} class="text-sm font-medium text-accent hover:underline">← Back to Events</a>
    </div>
  </article>
</BaseLayout>
