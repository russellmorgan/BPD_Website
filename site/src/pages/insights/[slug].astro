---
import BaseLayout from '../../layouts/BaseLayout.astro';
import posts from '../../data/posts.json';
import { url } from '../../lib/url.js';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;

const dateStr = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const excerpt = post.excerpt?.replace(/<[^>]*>/g, '').slice(0, 160) || '';
---

<BaseLayout title={post.title} description={excerpt}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-400 mb-6">
      <a href={url('/')} class="hover:text-accent">Home</a>
      <span class="mx-2">›</span>
      <a href={url('/insights/')} class="hover:text-accent">Insights</a>
      <span class="mx-2">›</span>
      <span class="text-slate-600 truncate">{post.title}</span>
    </nav>

    <!-- Categories -->
    <div class="flex flex-wrap gap-2 mb-4">
      {post.categories.map((cat) => (
        <a
          href={url(`/insights/${cat.slug}/`)}
          class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-accent-light text-accent hover:bg-accent hover:text-white transition-colors"
        >
          {cat.name}
        </a>
      ))}
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold text-brand leading-tight mb-4">{post.title}</h1>
    <time class="text-sm text-slate-400 block mb-8">{dateStr}</time>

    {post.content
      ? <div class="prose" set:html={post.content} />
      : <p class="text-slate-500 italic">Content not available.</p>
    }

    <!-- Back link -->
    <div class="mt-12 pt-8 border-t border-slate-100">
      <a href={url('/insights/')} class="text-sm font-medium text-accent hover:underline">← Back to Insights</a>
    </div>
  </article>
</BaseLayout>
