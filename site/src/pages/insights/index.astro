---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import taxonomy from '../../data/taxonomy.json';
import posts from '../../data/posts.json';

const cats = taxonomy.categories.filter((c) =>
  posts.some((p) => p.categories.some((pc) => pc.slug === c.slug))
);
---

<BaseLayout title="Insights" description="Healthcare marketing and strategy insights from BPD Healthcare.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-brand mb-2">Insights</h1>
    <p class="text-slate-500 mb-8">Strategy, brand, communications, and marketing perspectives from our team.</p>

    <div class="mb-8">
      <CategoryFilter categories={cats} basePath="/insights/category/" allHref="/insights/" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((post) => (
        <PostCard
          title={post.title}
          slug={post.slug}
          date={post.date}
          excerpt={post.excerpt || post.content}
          categories={post.categories}
          href={`/insights/${post.slug}/`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
