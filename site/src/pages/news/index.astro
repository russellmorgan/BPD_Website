---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import news from '../../data/news.json';
---

<BaseLayout title="News" description="The latest news from BPD Healthcare.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-brand mb-2">News</h1>
    <p class="text-slate-500 mb-8">The latest news from BPD Healthcare. {news.length} articles.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {news.map((post) => (
        <PostCard
          title={post.title}
          slug={post.slug}
          date={post.date}
          excerpt={post.excerpt || post.content}
          categories={post.categories}
          badge="News"
          badgeColor="bg-rose-100 text-rose-800"
          href={`/news/${post.slug}/`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
