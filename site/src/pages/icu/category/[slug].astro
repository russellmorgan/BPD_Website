---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostCard from '../../../components/PostCard.astro';
import CategoryFilter from '../../../components/CategoryFilter.astro';
import taxonomy from '../../../data/taxonomy.json';
import icuBlog from '../../../data/icu-blog.json';
import icuUpdates from '../../../data/icu-updates.json';

const allPosts = [
  ...icuBlog.map((p) => ({ ...p, _type: 'Blog' as const })),
  ...icuUpdates.map((p) => ({ ...p, _type: 'Update' as const })),
].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const usedSlugs = new Set(allPosts.flatMap((p) => p.icuCategories.map((c) => c.slug)));
const cats = taxonomy.icuCategories.filter((c) => usedSlugs.has(c.slug));

export function getStaticPaths() {
  const all = [
    ...icuBlog.map((p) => ({ ...p, _type: 'Blog' as const })),
    ...icuUpdates.map((p) => ({ ...p, _type: 'Update' as const })),
  ];
  const used = new Set(all.flatMap((p) => p.icuCategories.map((c) => c.slug)));
  return taxonomy.icuCategories
    .filter((c) => used.has(c.slug))
    .map((cat) => ({
      params: { slug: cat.slug },
      props: { cat },
    }));
}

const { cat } = Astro.props;
const filtered = allPosts.filter((p) => p.icuCategories.some((c) => c.slug === cat.slug));
---

<BaseLayout title={`${cat.name} – ICU`} description={`ICU articles tagged with ${cat.name}.`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-brand mb-2">ICU: {cat.name}</h1>
    <p class="text-slate-500 mb-8">{filtered.length} articles</p>

    <div class="mb-8">
      <CategoryFilter categories={cats} basePath="/icu/category/" current={cat.slug} />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {filtered.map((post) => (
        <PostCard
          title={post.title}
          slug={post.slug}
          date={post.date}
          excerpt={post.excerpt || post.content}
          categories={post.icuCategories}
          badge={post._type}
          badgeColor={post._type === 'Blog' ? 'bg-blue-100 text-blue-800' : 'bg-orange-100 text-orange-800'}
          href={`/icu/${post.slug}/`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
