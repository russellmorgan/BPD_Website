---
import BaseLayout from '../../layouts/BaseLayout.astro';
import icuBlog from '../../data/icu-blog.json';
import icuUpdates from '../../data/icu-updates.json';
import { url } from '../../lib/url.js';

const allPosts = [
  ...icuBlog.map((p) => ({ ...p, _type: 'Blog' as const })),
  ...icuUpdates.map((p) => ({ ...p, _type: 'Update' as const })),
];

export function getStaticPaths() {
  const blog = icuBlog.map((p) => ({ ...p, _type: 'Blog' as const }));
  const updates = icuUpdates.map((p) => ({ ...p, _type: 'Update' as const }));
  const all = [...blog, ...updates];
  // Deduplicate slugs – later entry wins
  const seen = new Map<string, typeof all[0]>();
  all.forEach((p) => seen.set(p.slug, p));
  return Array.from(seen.values()).map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const dateStr = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const excerpt = post.excerpt?.replace(/<[^>]*>/g, '').slice(0, 160) || '';
---

<BaseLayout title={post.title} description={excerpt}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <nav class="text-sm text-slate-400 mb-6">
      <a href={url('/')} class="hover:text-accent">Home</a>
      <span class="mx-2">›</span>
      <a href={url('/icu/')} class="hover:text-accent">ICU</a>
      <span class="mx-2">›</span>
      <span class="text-slate-600 truncate">{post.title}</span>
    </nav>

    <div class="flex flex-wrap gap-2 mb-4">
      <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-semibold uppercase ${post._type === 'Blog' ? 'bg-blue-100 text-blue-800' : 'bg-orange-100 text-orange-800'}`}>
        {post._type}
      </span>
      {post.icuCategories.map((cat) => (
        <a
          href={url(`/icu/${cat.slug}/`)}
          class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-accent-light text-accent hover:bg-accent hover:text-white transition-colors"
        >
          {cat.name}
        </a>
      ))}
    </div>

    <h1 class="text-3xl sm:text-4xl font-bold text-brand leading-tight mb-4">{post.title}</h1>
    <time class="text-sm text-slate-400 block mb-8">{dateStr}</time>

    {post.content
      ? <div class="prose" set:html={post.content} />
      : <p class="text-slate-500 italic">Content not available.</p>
    }

    <div class="mt-12 pt-8 border-t border-slate-100">
      <a href={url('/icu/')} class="text-sm font-medium text-accent hover:underline">← Back to ICU</a>
    </div>
  </article>
</BaseLayout>
