---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import posts from '../data/posts.json';
import icuBlog from '../data/icu-blog.json';
import work from '../data/work.json';
import podcasts from '../data/podcasts.json';
import { url } from '../lib/url.js';

const latestPosts = posts.slice(0, 4);
const latestIcu = icuBlog.slice(0, 3);
const latestWork = work.slice(0, 3);
const latestPodcasts = podcasts.slice(0, 3);
---

<BaseLayout title="BPD Healthcare" description="Delivering the future to healthcare's leading brands.">
  <!-- Hero -->
  <section class="bg-brand text-white py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight mb-6">
        Delivering the future to healthcare's leading brands
      </h1>
      <p class="text-xl text-blue-200 mb-8 max-w-2xl mx-auto">
        Strategy, brand, communications, and marketing insights for the healthcare industry.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href={url('/insights/')} class="bg-white text-brand font-semibold px-6 py-3 rounded-lg hover:bg-blue-50 transition-colors">
          Read Insights
        </a>
        <a href={url('/work/')} class="border border-white text-white font-semibold px-6 py-3 rounded-lg hover:bg-white/10 transition-colors">
          See Our Work
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Insights -->
  <section class="py-14 px-4 bg-surface">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-brand">Latest Insights</h2>
        <a href={url('/insights/')} class="text-sm font-medium text-accent hover:underline">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {latestPosts.map((post) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            date={post.date}
            excerpt={post.excerpt || post.content}
            categories={post.categories}
            href={`/insights/${post.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ICU -->
  <section class="py-14 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h2 class="text-2xl font-bold text-brand">Issues &amp; Crisis Updates</h2>
          <p class="text-sm text-slate-500 mt-1">Policy intelligence for healthcare leaders</p>
        </div>
        <a href={url('/icu/')} class="text-sm font-medium text-accent hover:underline">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestIcu.map((post) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            date={post.date}
            excerpt={post.excerpt || post.content}
            categories={post.icuCategories}
            badge="ICU"
            badgeColor="bg-blue-100 text-blue-800"
            href={`/icu/${post.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Work -->
  {latestWork.length > 0 && (
    <section class="py-14 px-4 bg-surface">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-brand">Our Work</h2>
          <a href={url('/work/')} class="text-sm font-medium text-accent hover:underline">View all →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {latestWork.map((post) => (
            <PostCard
              title={post.title}
              slug={post.slug}
              date={post.date}
              excerpt={post.excerpt || post.content}
              categories={post.workTypes}
              badge="Case Study"
              badgeColor="bg-emerald-100 text-emerald-800"
              href={`/work/${post.slug}/`}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Podcast -->
  <section class="py-14 px-4">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold text-brand">Podcast</h2>
        <a href={url('/podcast/')} class="text-sm font-medium text-accent hover:underline">View all →</a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {latestPodcasts.map((post) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            date={post.date}
            excerpt={post.excerpt || post.content}
            categories={post.categories}
            badge="Podcast"
            badgeColor="bg-purple-100 text-purple-800"
            href={`/podcast/${post.slug}/`}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
