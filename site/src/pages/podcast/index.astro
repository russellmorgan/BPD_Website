---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import podcasts from '../../data/podcasts.json';
---

<BaseLayout title="Podcast" description="BPD Healthcare podcast episodes on healthcare marketing, strategy, and trends.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl font-bold text-brand mb-2">Podcast</h1>
    <p class="text-slate-500 mb-8">{podcasts.length} episodes on healthcare marketing, strategy, and consumer trends.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {podcasts.map((post) => (
        <PostCard
          title={post.title}
          slug={post.slug}
          date={post.date}
          excerpt={post.excerpt || post.content}
          categories={post.categories}
          badge="Podcast"
          badgeColor="bg-purple-100 text-purple-800"
          href={`/podcast/${post.slug}/`}
        />
      ))}
    </div>
  </div>
</BaseLayout>
