---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { url } from '../lib/url.js';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'BPD Healthcare', description = 'Delivering the future to healthcare\'s leading brands.' } = Astro.props;
const pageTitle = title === 'BPD Healthcare' ? title : `${title} | BPD Healthcare`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/x-icon" href={url('/favicon.ico')} />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-white text-slate-900 min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
